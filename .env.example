# Copia este archivo a ".env" y rellena solo lo que uses. No subas ".env" al repositorio.

# --- Proveedor (por defecto: ollama = gratis en tu PC) ---
# Valores: ollama | bedrock | openai | anthropic
# Si lo dejas vacío: se usa ollama salvo que definas OPENAI_API_KEY o ANTHROPIC_API_KEY.
LLM_PROVIDER=ollama

# Nombre del modelo según proveedor (opcional; hay un valor por defecto en código)
# Ollama: llama3.2, mistral, phi3, etc. (debes tenerlo descargado: ollama pull llama3.2)
# OpenAI: gpt-4o
# Bedrock: us.anthropic.claude-sonnet-4-20250514-v1:0
MODEL_ID=llama3.2

# --- Ollama (gratis, local; instala https://ollama.com y ejecuta "ollama serve") ---
OLLAMA_HOST=http://127.0.0.1:11434
# Opcional
# OLLAMA_TEMPERATURE=0.4

# --- OpenAI (de pago; https://platform.openai.com/api-keys ) ---
OPENAI_API_KEY=
# OPENAI_BASE_URL=

# --- Anthropic (de pago) ---
ANTHROPIC_API_KEY=

# --- Amazon Bedrock / AWS (de pago salvo créditos; requiere LLM_PROVIDER=bedrock o credenciales) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
AWS_REGION=us-west-2
# AWS_BEARER_TOKEN_BEDROCK=
