# Copia este archivo a ".env" y rellena los valores. No subas ".env" al repositorio.

# --- Proveedor de modelo (bedrock | openai | anthropic) ---
# Por defecto el SDK usa Amazon Bedrock si no pasas un modelo explícito.
LLM_PROVIDER=bedrock

# ID del modelo (opcional; si se omite, cada proveedor usa un valor por defecto razonable)
# Ejemplos Bedrock: us.anthropic.claude-sonnet-4-20250514-v1:0
# Ejemplos OpenAI: gpt-4o
# Ejemplos Anthropic API: claude-sonnet-4-20250514
MODEL_ID=

# --- Amazon Bedrock / AWS (recomendado con LLM_PROVIDER=bedrock o credenciales por defecto) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Opcional (sesiones temporales)
AWS_SESSION_TOKEN=
AWS_REGION=us-west-2
# Alternativa al nombre anterior
# AWS_DEFAULT_REGION=us-west-2

# Opcional: token de portador para Bedrock (si tu flujo lo usa)
# AWS_BEARER_TOKEN_BEDROCK=

# --- OpenAI (requiere instalar el extra: strands-agents[openai]) ---
OPENAI_API_KEY=
# Opcional: endpoint compatible con OpenAI (Azure, gateways, etc.)
OPENAI_BASE_URL=

# --- Anthropic API directa (requiere instalar el extra: strands-agents[anthropic]) ---
ANTHROPIC_API_KEY=
